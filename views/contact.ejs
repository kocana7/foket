<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="page-header">
  <div class="container">
    <div class="breadcrumb"><a href="/">Home</a> › <span><%= t.contact.title %></span></div>
    <h1><%= t.contact.title %></h1>
    <p><%= t.contact.subtitle %></p>
  </div>
</div>

<section class="section" style="padding-top:60px;">
  <div class="container">
    <% if(success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success_msg %></div>
    <% } %>
    <% if(error_msg && error_msg.length > 0) { %>
      <div class="alert alert-error"><i class="fas fa-times-circle"></i> <%= error_msg %></div>
    <% } %>
    <div class="contact-grid">
      <div class="contact-info">
        <div class="contact-item">
          <div class="contact-item-icon"><i class="fas fa-envelope"></i></div>
          <div>
            <div class="contact-item-label">Email</div>
            <div class="contact-item-value">support@foketcrypto.com</div>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon"><i class="fab fa-telegram-plane"></i></div>
          <div>
            <div class="contact-item-label">Telegram</div>
            <div class="contact-item-value">@foketcrypto</div>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon"><i class="fas fa-phone"></i></div>
          <div>
            <div class="contact-item-label">Phone</div>
            <div class="contact-item-value">+1-800-000-0000</div>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon"><i class="fas fa-map-marker-alt"></i></div>
          <div>
            <div class="contact-item-label">Address</div>
            <div class="contact-item-value">123 Crypto Street, London, EC1R 5HL</div>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-item-icon"><i class="fas fa-clock"></i></div>
          <div>
            <div class="contact-item-label">Business Hours</div>
            <div class="contact-item-value">Mon-Fri, 9:00 AM - 6:00 PM UTC</div>
          </div>
        </div>
      </div>
      <div class="contact-form">
        <form action="/contact" method="POST">
          <div class="form-group">
            <label class="form-label"><%= t.contact.name %></label>
            <input type="text" name="name" class="form-control" required placeholder="John Doe">
          </div>
          <div class="form-group">
            <label class="form-label"><%= t.contact.email %></label>
            <input type="email" name="email" class="form-control" required placeholder="john@example.com">
          </div>
          <div class="form-group">
            <label class="form-label"><%= t.contact.subject %></label>
            <input type="text" name="subject" class="form-control" placeholder="How can we help?">
          </div>
          <div class="form-group">
            <label class="form-label"><%= t.contact.message %></label>
            <textarea name="message" class="form-control" rows="5" required placeholder="Your message..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">
            <i class="fas fa-paper-plane"></i>
            <%= t.contact.send %>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
