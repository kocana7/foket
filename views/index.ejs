<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">
        <div class="dot"></div>
        <%= t.hero.badge %>
      </div>
      <h1 class="hero-title">
        <%= t.hero.title %>
        <br><span class="highlight"><%= t.hero.title_highlight %></span>
      </h1>
      <p class="hero-subtitle"><%= t.hero.subtitle %></p>
      <div class="hero-perks">
        <div class="hero-perk"><div class="check"><i class="fas fa-check"></i></div><%= t.hero.free_signals_week %></div>
        <div class="hero-perk"><div class="check"><i class="fas fa-check"></i></div><%= t.hero.vip_signals_day %></div>
        <div class="hero-perk"><div class="check"><i class="fas fa-check"></i></div><%= t.hero.money_back %></div>
      </div>
      <div class="hero-buttons">
        <a href="#" class="btn btn-primary btn-lg">
          <i class="fab fa-telegram-plane"></i>
          <%= t.hero.join_free_btn %>
        </a>
        <a href="/pricing" class="btn btn-outline btn-lg">
          <%= t.hero.view_vip_btn %>
          <i class="fas fa-arrow-right"></i>
        </a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat-value" data-count="<%= stats.total_members || '50000' %>+">50,000+</div>
          <div class="hero-stat-label"><%= t.stats.members %></div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-value" data-count="<%= stats.success_rate || '82' %>%">82%</div>
          <div class="hero-stat-label"><%= t.stats.success_rate %></div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-value" data-count="<%= stats.years_active || '10' %>+">10+</div>
          <div class="hero-stat-label"><%= t.stats.years %></div>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card-main">
        <div class="signal-card-header">
          <div class="signal-card-coin">
            <div class="coin-icon btc-color">BTC</div>
            <div>
              <div class="coin-name">Bitcoin</div>
              <div class="coin-pair">BTC/USDT</div>
            </div>
          </div>
          <div class="signal-type-badge long">LONG</div>
        </div>
        <div class="signal-grid">
          <div class="signal-item">
            <div class="signal-item-label">Entry Price</div>
            <div class="signal-item-value">$65,000</div>
          </div>
          <div class="signal-item">
            <div class="signal-item-label">Take Profit</div>
            <div class="signal-item-value green">$68,500</div>
          </div>
          <div class="signal-item">
            <div class="signal-item-label">Stop Loss</div>
            <div class="signal-item-value red">$62,000</div>
          </div>
          <div class="signal-item">
            <div class="signal-item-label">Risk/Reward</div>
            <div class="signal-item-value">1:2.5</div>
          </div>
        </div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:12px;">Risk: 1% &nbsp;|&nbsp; Exchange: Binance</div>
        <div class="signal-progress">
          <div class="signal-progress-bar"></div>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--text-muted);margin-top:6px;">
          <span>Entry</span><span style="color:var(--accent-blue)">+65% to TP</span>
        </div>
      </div>
      <!-- Floating badges -->
      <div style="margin-top:16px;">
        <div class="floating-badge">
          <span style="color:var(--accent-green);font-size:20px;">✓</span>
          <div>
            <div style="font-weight:700;font-size:13px;">ETH/USDT +23.4%</div>
            <div style="font-size:11px;color:var(--text-muted);">Target reached</div>
          </div>
        </div>
        <div class="floating-badge">
          <span style="font-size:20px;">📊</span>
          <div>
            <div style="font-weight:700;font-size:13px;">82% Win Rate</div>
            <div style="font-size:11px;color:var(--text-muted);">This month</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stats-grid">
    <div>
      <div class="stat-item-num" data-count="<%= stats.total_members || '50000' %>+">50,000+</div>
      <div class="stat-item-label"><%= t.stats.members %></div>
    </div>
    <div>
      <div class="stat-item-num" data-count="<%= stats.success_rate || '82' %>%">82%</div>
      <div class="stat-item-label"><%= t.stats.success_rate %></div>
    </div>
    <div>
      <div class="stat-item-num" data-count="<%= stats.signals_delivered || '15000' %>+">15,000+</div>
      <div class="stat-item-label"><%= t.stats.signals %></div>
    </div>
    <div>
      <div class="stat-item-num" data-count="<%= stats.years_active || '10' %>+">10+</div>
      <div class="stat-item-label"><%= t.stats.years %></div>
    </div>
  </div>
</div>

<!-- FEATURES -->
