        <div class="feature-desc"><%= t.features.ai_desc %></div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👨‍💼</div>
        <div class="feature-title"><%= t.features.expert_title %></div>
        <div class="feature-desc"><%= t.features.expert_desc %></div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🛡️</div>
        <div class="feature-title"><%= t.features.risk_title %></div>
        <div class="feature-desc"><%= t.features.risk_desc %></div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⚡</div>
        <div class="feature-title"><%= t.features.instant_title %></div>
        <div class="feature-desc"><%= t.features.instant_desc %></div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">💬</div>
        <div class="feature-title"><%= t.features.support_title %></div>
        <div class="feature-desc"><%= t.features.support_desc %></div>
      </div>
      <div class="feature-card">
