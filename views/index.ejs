    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section how-it-works" id="how-it-works">
  <div class="container">
    <div class="section-header">
      <div class="section-badge">📋 Signal Format</div>
      <h2 class="section-title"><%= t.how_it_works.title %></h2>
      <p class="section-subtitle"><%= t.how_it_works.subtitle %></p>
    </div>
    <div class="signal-format-grid">
      <div class="signal-format-item">
        <div class="format-num">1</div>
        <div class="format-title"><%= t.how_it_works.entry %></div>
        <div class="format-desc"><%= t.how_it_works.entry_desc %></div>
      </div>
      <div class="signal-format-item">
        <div class="format-num">2</div>
        <div class="format-title"><%= t.how_it_works.take_profit %></div>
        <div class="format-desc"><%= t.how_it_works.take_profit_desc %></div>
      </div>
      <div class="signal-format-item">
        <div class="format-num">3</div>
        <div class="format-title"><%= t.how_it_works.stop_loss %></div>
        <div class="format-desc"><%= t.how_it_works.stop_loss_desc %></div>
      </div>
      <div class="signal-format-item">
        <div class="format-num">4</div>
        <div class="format-title"><%= t.how_it_works.risk %></div>
        <div class="format-desc"><%= t.how_it_works.risk_desc %></div>
      </div>
      <div class="signal-format-item">
        <div class="format-num">5</div>
        <div class="format-title"><%= t.how_it_works.rr_ratio %></div>
        <div class="format-desc"><%= t.how_it_works.rr_ratio_desc %></div>
      </div>
    </div>
  </div>
</section>

