<%- include('partials/layout') %>
<% locals.topbarAction = '<a href="/admin/signals/new" class="topbar-btn primary"><i class="fas fa-plus"></i> New Signal</a>'; %>

<div class="admin-card">
  <div class="admin-card-header">
    <div class="admin-card-title">All Signals (<%= total %>)</div>
  </div>
  <div style="overflow-x:auto;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Coin / Pair</th>
          <th>Type</th>
          <th>Entry</th>
          <th>TP1</th>
          <th>Stop Loss</th>
          <th>Risk</th>
          <th>Tier</th>
          <th>Status</th>
          <th>Result</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if(signals && signals.length > 0) { %>
          <% signals.forEach(sig => { %>
            <tr>
              <td>
                <div style="font-weight:700;" class="text-primary"><%= sig.pair %></div>
                <div style="font-size:11px;color:var(--admin-text-muted);"><%= sig.exchange || '—' %></div>
              </td>
              <td><span class="badge <%= sig.signal_type === 'LONG' ? 'badge-green' : 'badge-red' %>"><%= sig.signal_type %></span></td>
              <td class="text-primary">$<%= Number(sig.entry_price).toLocaleString('en',{maximumFractionDigits:4}) %></td>
              <td style="color:#3fb950;">$<%= Number(sig.take_profit_1).toLocaleString('en',{maximumFractionDigits:4}) %></td>
              <td style="color:#f85149;">$<%= Number(sig.stop_loss).toLocaleString('en',{maximumFractionDigits:4}) %></td>
              <td><%= sig.risk_percentage %>%</td>
              <td><span class="badge <%= sig.tier === 'vip' ? 'badge-purple' : 'badge-blue' %>"><%= sig.tier.toUpperCase() %></span></td>
              <td><span class="badge <%= sig.status === 'active' ? 'badge-yellow' : sig.status === 'closed' ? 'badge-gray' : 'badge-red' %>"><%= sig.status.toUpperCase() %></span></td>
              <td><span class="badge <%= sig.result === 'win' ? 'badge-green' : sig.result === 'loss' ? 'badge-red' : 'badge-blue' %>"><%= sig.result.toUpperCase() %></span></td>
              <td style="font-size:12px;"><%= new Date(sig.created_at).toLocaleDateString() %></td>
              <td>
                <div style="display:flex;gap:6px;">
                  <a href="/admin/signals/<%= sig.id %>/edit" class="btn-admin btn-admin-outline btn-admin-sm"><i class="fas fa-edit"></i></a>
                  <form action="/admin/signals/<%= sig.id %>/delete" method="POST" data-confirm="Delete this signal?">
                    <button type="submit" class="btn-admin btn-admin-danger btn-admin-sm"><i class="fas fa-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="11" style="text-align:center;padding:40px;color:var(--admin-text-muted);">No signals yet. <a href="/admin/signals/new">Create one</a></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if(pages > 1) { %>
<div class="admin-pagination">
  <% for(let i=1;i<=pages;i++) { %>
    <a href="?page=<%= i %>" class="admin-page-btn <%= page === i ? 'active' : '' %>"><%= i %></a>
  <% } %>
</div>
<% } %>

<%- include('partials/layout-end') %>
