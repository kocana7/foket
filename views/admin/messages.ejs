<%- include('partials/layout') %>

<div class="admin-card">
  <div class="admin-card-header">
    <div class="admin-card-title">Contact Messages (<%= messages.length %>)</div>
  </div>
  <% if(messages && messages.length > 0) { %>
    <% messages.forEach(msg => { %>
      <div style="padding:16px 20px;border-bottom:1px solid var(--admin-border);display:grid;grid-template-columns:1fr auto;gap:16px;align-items:start;">
        <div>
          <div style="display:flex;gap:12px;align-items:center;margin-bottom:6px;">
            <div style="font-weight:700;font-size:14px;color:var(--admin-text);">
              <%= msg.name %> <span style="color:var(--admin-text-muted);font-weight:400;">— <%= msg.email %></span>
            </div>
            <span class="badge badge-blue" style="font-size:10px;"><%= msg.subject || 'No subject' %></span>
          </div>
          <p style="font-size:13px;color:var(--admin-text-secondary);line-height:1.6;"><%= msg.message %></p>
          <div style="font-size:11px;color:var(--admin-text-muted);margin-top:8px;">
            <i class="fas fa-clock"></i> <%= new Date(msg.created_at).toLocaleString() %>
          </div>
        </div>
        <div>
          <form action="/admin/messages/<%= msg.id %>/delete" method="POST" data-confirm="Delete this message?">
            <button type="submit" class="btn-admin btn-admin-danger btn-admin-sm"><i class="fas fa-trash"></i></button>
          </form>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div style="text-align:center;padding:60px;color:var(--admin-text-muted);">
      <i class="fas fa-inbox" style="font-size:36px;margin-bottom:12px;display:block;"></i>
      No messages yet
    </div>
  <% } %>
</div>

<%- include('partials/layout-end') %>
