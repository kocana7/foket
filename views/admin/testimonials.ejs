<%- include('partials/layout') %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start;">
  <!-- Add Form -->
  <div class="admin-card">
    <div class="admin-card-header">
      <div class="admin-card-title">Add Testimonial</div>
    </div>
    <div class="admin-card-body">
      <form action="/admin/testimonials" method="POST">
        <div class="form-group">
          <label class="form-label required">Name</label>
          <input type="text" name="name" class="form-control" placeholder="John D." required>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Country</label>
            <input type="text" name="country" class="form-control" placeholder="United States">
          </div>
          <div class="form-group">
            <label class="form-label">Plan</label>
            <input type="text" name="plan_name" class="form-control" placeholder="The Expert">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label required">Review Text</label>
          <textarea name="text" class="form-control" rows="3" required placeholder="Their review..."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Rating (1-5)</label>
          <select name="rating" class="form-control">
            <option value="5">5 ⭐⭐⭐⭐⭐</option>
            <option value="4">4 ⭐⭐⭐⭐</option>
            <option value="3">3 ⭐⭐⭐</option>
            <option value="2">2 ⭐⭐</option>
            <option value="1">1 ⭐</option>
          </select>
        </div>
        <button type="submit" class="btn-admin btn-admin-primary" style="width:100%;justify-content:center;">
          <i class="fas fa-plus"></i> Add Testimonial
        </button>
      </form>
    </div>
  </div>

  <!-- List -->
  <div class="admin-card">
    <div class="admin-card-header">
      <div class="admin-card-title">All Testimonials (<%= testimonials.length %>)</div>
    </div>
    <% if(testimonials && testimonials.length > 0) { %>
      <% testimonials.forEach(t => { %>
        <div style="padding:14px 16px;border-bottom:1px solid var(--admin-border);display:flex;justify-content:space-between;gap:12px;">
          <div>
            <div style="font-weight:700;font-size:13px;color:var(--admin-text);">
              <%= t.name %> <%= t.country ? '· ' + t.country : '' %>
              <span style="color:#d29922;"><%for(let i=0;i<t.rating;i++){%>★<%}%></span>
            </div>
            <div style="font-size:12px;color:var(--admin-text-secondary);margin-top:4px;"><%= t.text.substring(0,100) %>...</div>
            <div style="font-size:11px;color:var(--admin-text-muted);margin-top:4px;"><%= t.plan_name || '' %></div>
          </div>
          <form action="/admin/testimonials/<%= t.id %>/delete" method="POST" data-confirm="Delete?">
            <button type="submit" class="btn-admin btn-admin-danger btn-admin-sm"><i class="fas fa-trash"></i></button>
          </form>
        </div>
      <% }) %>
    <% } else { %>
      <div style="text-align:center;padding:40px;color:var(--admin-text-muted);">No testimonials yet</div>
    <% } %>
  </div>
</div>

<%- include('partials/layout-end') %>
