<%
const langFlags = { ko: '🇰🇷', en: '🇺🇸', de: '🇩🇪', ja: '🇯🇵', zh: '🇨🇳', fr: '🇫🇷', es: '🇪🇸' };
const langNames = { ko: '한국어', en: 'English', de: 'Deutsch', ja: '日本語', zh: '中文', fr: 'Français', es: 'Español' };
%>
<!-- Ticker Bar -->
<div class="ticker-bar">
  <div class="ticker-inner" id="tickerInner">
    <div class="ticker-item"><span class="coin-symbol">BTC</span><span class="price">$65,432</span><span class="change up">+2.34%</span></div>
    <div class="ticker-item"><span class="coin-symbol">ETH</span><span class="price">$3,241</span><span class="change up">+1.87%</span></div>
    <div class="ticker-item"><span class="coin-symbol">BNB</span><span class="price">$385</span><span class="change down">-0.54%</span></div>
    <div class="ticker-item"><span class="coin-symbol">ADA</span><span class="price">$0.452</span><span class="change up">+3.12%</span></div>
    <div class="ticker-item"><span class="coin-symbol">DOT</span><span class="price">$8.32</span><span class="change up">+1.45%</span></div>
    <div class="ticker-item"><span class="coin-symbol">LINK</span><span class="price">$14.87</span><span class="change up">+2.91%</span></div>
    <div class="ticker-item"><span class="coin-symbol">XRP</span><span class="price">$0.623</span><span class="change down">-1.23%</span></div>
    <div class="ticker-item"><span class="coin-symbol">LTC</span><span class="price">$82.41</span><span class="change up">+0.87%</span></div>
  </div>
</div>

<!-- Navbar -->
<nav class="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-brand">
      <div class="logo-icon">₿</div>
      Foket<span>Crypto</span>
    </a>
    <div class="navbar-nav">
      <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>"><%= t.nav.home %></a>
      <a href="/crypto-signals" class="<%= currentPage === 'signals' ? 'active' : '' %>"><%= t.nav.signals %></a>
      <a href="/pricing" class="<%= currentPage === 'pricing' ? 'active' : '' %>"><%= t.nav.pricing %></a>
      <a href="/news" class="<%= currentPage === 'news' ? 'active' : '' %>"><%= t.nav.news %></a>
      <a href="/contact" class="<%= currentPage === 'contact' ? 'active' : '' %>"><%= t.nav.contact %></a>
    </div>
    <div class="navbar-actions">
      <!-- Language Switcher -->
      <div class="lang-dropdown">
        <button class="lang-switcher" id="langToggle">
          <span><%= langFlags[lang] || '🌐' %></span>
          <span class="lang-switcher-text"><%= langNames[lang] || lang.toUpperCase() %></span>
          <span>▾</span>
        </button>
        <div class="lang-dropdown-menu" id="langMenu">
          <% supportedLangs.forEach(l => { %>
            <a href="?lang=<%= l %>" class="lang-option <%= l === lang ? 'current' : '' %>">
              <span class="lang-flag"><%= langFlags[l] %></span>
              <span><%= langNames[l] %></span>
              <% if(l === lang) { %><span style="margin-left:auto;">✓</span><% } %>
            </a>
          <% }) %>
        </div>
      </div>
      <a href="#" class="btn-telegram">
        <i class="fab fa-telegram-plane"></i>
        <span class="lang-switcher-text"><%= t.nav.join_free %></span>
      </a>
    </div>
    <button class="hamburger" id="hamburger">&#9776;</button>
  </div>
  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/"><%= t.nav.home %></a>
    <a href="/crypto-signals"><%= t.nav.signals %></a>
    <a href="/pricing"><%= t.nav.pricing %></a>
    <a href="/news"><%= t.nav.news %></a>
    <a href="/contact"><%= t.nav.contact %></a>
    <% supportedLangs.forEach(l => { %>
      <a href="?lang=<%= l %>" style="font-size:12px;"><%= langFlags[l] %> <%= langNames[l] %></a>
    <% }) %>
  </div>
</nav>
