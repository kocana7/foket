# Google OAuth - Google Cloud Console에서 발급
# https://console.cloud.google.com → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT 비밀키 (운영 환경에서 반드시 변경)
JWT_SECRET=foket-jwt-secret-change-in-production

# 관리자 API 키
ADMIN_KEY=foket-admin-2026

# DB 설정 (Windows 인증 사용 시 비워두기)
DB_SERVER=localhost
DB_NAME=FoketDB
DB_USER=
DB_PASS=Foket2026

PORT=4000
