DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=foketcrypto_db

# MSSQL (Foket 관리자/메인 페이지 데이터 저장용 – 설정 시 DB에 저장)
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=YourMssqlPassword
MSSQL_DATABASE=FoketDB
MSSQL_TRUST_CERT=true

SESSION_SECRET=your-super-secret-session-key-change-this

PORT=3000
NODE_ENV=development

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
